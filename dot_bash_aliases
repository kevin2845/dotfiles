#Install packages for dev environement
alias kevpkg="$HOME/.scripts/install-packages.sh"
alias src='source $HOME/.bashrc'
alias kevupd='$HOME/.scripts/update.sh'
alias chap='chezmoi apply && source "$HOME/.bashrc"'
alias chup='chezmoi update && source "$HOME/.bashrc"'


#stuff that annoys me
alias python='python3'

#QoL
alias please='sudo $(history -p "!!")'

#Sudo QoL
alias zypper='sudo zypper'
alias dnf='sudo dnf'
alias pacman='sudo pacman'


# ls alias with checks
if command -v eza >/dev/null 2>&1; then
  alias ls='eza --icons -F -x'
  alias l='eza --icons -F -1'
  alias ll='eza --icons -l -h -a --git'
  alias la='eza --icons -a'
  alias lt='eza -T -L'
  alias ltd='eza -T -l -h --git'
else
  alias l='ls -1'
  alias ll='ls -lah'
  alias la='ls -A'
  alias lt='ls'
  alias ltd='ls -lah'
fi

alias ce='chezmoi edit --watch'


# scripts
alias sesh='$HOME/.scripts/tmux-sessionizer.sh'
alias sweep-dns='$HOME/.scripts/sweep-dns.sh' 
alias sweep-ip='$HOME/.scripts/sweep-ip.sh'
